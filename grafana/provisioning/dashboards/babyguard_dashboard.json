          "query": "from(bucket: \"babyguard_bucket\")\n  |> range(start: -1d)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"alerts\")\n  |> filter(fn: (r) => r[\"shirt_id\"] == \"${shirt_id}\")\n  |> filter(fn: (r) => r[\"_field\"] == \"is_resolved\")\n  |> last()\n  |> map(fn: (r) => ({ _time: r._time, _value: if r._value == 0 then \"CRITICO\" else \"STABILE\" }))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "match": "null",
                "result": {
                  "color": "green",
                  "text": "STABILE"
