      "id": 1,
      "title": "Frequenza Cardiaca (Heart Rate)",
      "type": "timeseries",
      "datasource": {
        "type": "influxdb",
        "uid": "babyguard-influxdb"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "babyguard-influxdb"
          },
          "query": "from(bucket: \"babyguard_bucket\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"vitals_summary\")\n  |> filter(fn: (r) => r[\"shirt_id\"] == \"${shirt_id}\")\n  |> filter(fn: (r) => r[\"_field\"] == \"heartrate\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "unit": "bpm",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 160
