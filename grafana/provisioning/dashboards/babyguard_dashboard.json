              },
              "type": "special"
            },
            {
              "options": {
                "match": "empty",
                "result": {
                  "color": "green",
                  "text": "STABILE"
                }
              },
              "type": "special"
            },
            {
              "options": {
                "STABILE": {
                  "color": "green",
                  "index": 0,
                  "text": "STABILE"
