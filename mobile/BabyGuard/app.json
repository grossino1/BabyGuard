{
  "expo": {
    "name": "BabyGuard",
    "slug": "BabyGuard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/LogoBabyGuard.jpeg",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/LogoBabyGuard.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#0d2537"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aparzialeunisa.AppNotify",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/LogoBabyGuard.jpeg",
        "backgroundColor": "#0d2537"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.aparzialeunisa.AppNotify",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
